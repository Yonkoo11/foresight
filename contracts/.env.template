# CT League - Smart Contract Deployment Configuration
# Base Sepolia Testnet

# ========================================
# REQUIRED: Deployer Wallet
# ========================================
# Your wallet private key (KEEP THIS SECRET!)
# Get from MetaMask: Settings → Security & Privacy → Reveal Private Key
# NEVER share or commit this!
PRIVATE_KEY=your_private_key_here_without_0x_prefix

# ========================================
# REQUIRED: RPC Endpoint
# ========================================
# Base Sepolia RPC URL
# Option 1: Use public RPC (may be slow)
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Option 2: Get free RPC from Alchemy (recommended)
# 1. Go to: https://www.alchemy.com/
# 2. Create account (free)
# 3. Create new app → Base Sepolia
# 4. Copy HTTP URL
# BASE_SEPOLIA_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_API_KEY

# Option 3: Use Infura
# BASE_SEPOLIA_RPC_URL=https://base-sepolia.infura.io/v3/YOUR_API_KEY

# ========================================
# REQUIRED: Contract Verification
# ========================================
# Basescan API Key (for verifying contracts)
# 1. Go to: https://basescan.org/register
# 2. Create account
# 3. Go to API-KEYs → Add
# 4. Copy API key
ETHERSCAN_API_KEY=your_basescan_api_key_here

# ========================================
# OPTIONAL: Backend Wallets
# ========================================
# Keeper wallet (resolves predictions, runs cron jobs)
# If not set, deployer wallet will be used
# KEEPER_ADDRESS=0x...

# Oracle wallet (resolves price feeds, narrative duels)
# If not set, deployer wallet will be used
# ORACLE_ADDRESS=0x...

# ========================================
# TESTNET FUNDING
# ========================================
# Get Base Sepolia ETH from:
# - https://www.alchemy.com/faucets/base-sepolia
# - https://docs.base.org/tools/network-faucets
#
# Recommended: 0.5 ETH for deployment + testing
