# ============================================
# Timecaster Backend - Environment Variables
# ============================================
# Copy this file to .env and fill in your values

# ============================================
# Server Configuration
# ============================================

# Port the server will run on
PORT=3001

# Environment (development | production)
NODE_ENV=development

# ============================================
# Database Configuration
# ============================================

# PostgreSQL connection string
# Format: postgresql://[user[:password]@][host][:port][/database]
# Local example (no password): postgresql://localhost:5432/timecaster
# Production example: postgresql://user:password@host:5432/timecaster?ssl=true
DATABASE_URL=postgresql://localhost:5432/timecaster

# ============================================
# Authentication
# ============================================

# JWT secret key for signing tokens
# IMPORTANT: Generate a random string for production!
# You can use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ============================================
# Blockchain Configuration
# ============================================

# Base Network RPC URL
# Sepolia (testnet): https://sepolia.base.org
# Mainnet: https://mainnet.base.org
RPC_URL=https://sepolia.base.org

# Chain ID
# Base Sepolia: 84532
# Base Mainnet: 8453
CHAIN_ID=84532

# ============================================
# Smart Contract Addresses
# ============================================

# CT Draft contract address (from your Foundry deployment)
CT_DRAFT_ADDRESS=0x01C5ca0b837E5FC057CF31FA6aD28786261dA13e

# Reputation Engine contract address
REPUTATION_ENGINE_ADDRESS=0xYourReputationAddress

# Treasury contract address
TREASURY_ADDRESS=0xYourTreasuryAddress

# ============================================
# Frontend Configuration
# ============================================

# Frontend URL for CORS configuration
# Development: http://localhost:5173
# Production: https://yourdomain.com
FRONTEND_URL=http://localhost:5173

# ============================================
# Twitter API (Optional)
# ============================================

# Twitter API v2 credentials
# Required for real-time influencer data scraping
# Get these from: https://developer.twitter.com/en/portal/dashboard
#
# If not provided:
# - Twitter scraper will be disabled
# - Influencer data will use static values
# - Scoring will still work with existing data

# Twitter API Key (v2)
TWITTER_API_KEY=

# Twitter API Secret (v2)
TWITTER_API_SECRET=

# Twitter Bearer Token (v2) - Most important for API v2
TWITTER_BEARER_TOKEN=

# ============================================
# Optional Features
# ============================================

# Rate limiting (requests per 15 minutes)
# Default: 100
RATE_LIMIT_MAX=100

# Session expiry (in hours)
# Default: 24
SESSION_EXPIRY_HOURS=24

# Enable debug logging (true | false)
DEBUG=false
