# ============================================
# Foresight Backend - Environment Variables
# ============================================
# Copy this file to .env and fill in your values

# ============================================
# Server Configuration
# ============================================
PORT=3001
NODE_ENV=development

# ============================================
# Database (PostgreSQL)
# ============================================
# Local: postgresql://localhost:5432/foresight
# Railway: Automatically set via DATABASE_URL plugin
DATABASE_URL=postgresql://localhost:5432/foresight

# ============================================
# Authentication — Privy (REQUIRED)
# ============================================
# Get from https://dashboard.privy.io
PRIVY_APP_ID=
PRIVY_APP_SECRET=

# JWT secret for session tokens (ROTATE before production!)
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# WARNING: Old secrets exist in git history. Always use a freshly generated value.
JWT_SECRET=change-me-in-production

# JWT access token lifetime (default: 15m). Refresh tokens last 30d.
# JWT_EXPIRES_IN=15m

# Encryption key for sensitive data at rest (Twitter tokens, etc.)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# IMPORTANT: This must be different from JWT_SECRET. Rotating JWT_SECRET
# must NOT break encrypted data. Keep this key stable.
ENCRYPTION_KEY=change-me-in-production

# ============================================
# Tapestry Protocol — Social Layer (optional)
# ============================================
# Get from https://www.usetapestry.dev
# Without this, scores won't store on-chain
TAPESTRY_API_KEY=

# ============================================
# Twitter Data Pipeline (optional)
# ============================================
# Get from https://twitterapi.io (~$0.70/month)
# Without this, CT Feed won't auto-refresh
TWITTER_API_IO_KEY=

# ============================================
# Frontend URL (CORS)
# ============================================
# Development: http://localhost:5173
# Production: https://ct-foresight.xyz (or your domain)
FRONTEND_URL=http://localhost:5173
