# ============================================================================
# CT league Frontend Configuration
# ============================================================================

# Reown Project ID (formerly WalletConnect)
# Get free project ID from: https://cloud.reown.com
# Required for wallet connection (MetaMask, Coinbase Wallet, etc.)
VITE_WALLETCONNECT_PROJECT_ID=414cde2e1b60012cfb428ceff08653c9

# Backend API URL
VITE_API_URL=http://localhost:3001

# Base Sepolia RPC URL (optional - defaults to public RPC)
# Get free RPC from: https://www.alchemy.com or https://infura.io
# Public RPC: https://sepolia.base.org
VITE_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# ============================================================================
# Smart Contract Addresses (update after deployment)
# Copy these from the output of: forge script script/Deploy.s.sol
# ============================================================================

# Core Infrastructure
VITE_TREASURY_ADDRESS=0x0000000000000000000000000000000000000000
VITE_REPUTATION_ENGINE_ADDRESS=0x0000000000000000000000000000000000000000
VITE_FORESIGHT_NFT_ADDRESS=0x0000000000000000000000000000000000000000

# Game Contracts
VITE_CT_DRAFT_ADDRESS=0x0000000000000000000000000000000000000000
VITE_TIMECASTER_ARENA_ADDRESS=0x0000000000000000000000000000000000000000
VITE_DAILY_GAUNTLET_ADDRESS=0x0000000000000000000000000000000000000000
